// Test @section occurrence
@section .x=8 .z=8 {
  [0, 0, 0] oak_log
  [0, 1, 0] oak_log
  [0, 2, 0] oak_log
  [-1, 3, 0] oak_leaves
  [0, 3, 0] oak_leaves
  [1, 3, 0] oak_leaves
  [-2, 4, 0] oak_leaves
  [-1, 4, 0] oak_leaves
  [0, 4, 0] oak_leaves
  [1, 4, 0] oak_leaves
  [2, 4, 0] oak_leaves
}

// Test with y offset
@section .x=0 .y=10 .z=0 {
  [0, 0, 0] diamond_block
}

// Test with all defaults (should place at 0,0,0 of section)
@section {
  [0, 0, 0] emerald_block
}
